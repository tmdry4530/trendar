PORT=4000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=agent_radar

# GitHub Personal Access Token (권장: 5000 req/hr)
GITHUB_TOKEN=

# ETL
ETL_CRON=0 */6 * * *
ETL_PER_QUERY=30
ETL_MIN_STARS=1000           # 이 값 이상(>=) 스타만 수집/저장. 0 = 제한 없음

# CORS (프론트 dev 서버)
CORS_ORIGIN=http://localhost:5173
