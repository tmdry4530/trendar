PORT=4000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=trendar

# GitHub OAuth App (dev/prod 각각 별도 앱 등록 — 콜백 URL이 1개뿐)
# dev 콜백: http://localhost:5173/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# 인증/세션
# TOKEN_ENCRYPTION_KEY: 64자 hex(32바이트). 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=
APP_URL=http://localhost:5173
SESSION_TTL_DAYS=30

# 사용자당 watch query 최대 개수
MAX_QUERIES_PER_USER=10

# ETL
ETL_CRON=0 */6 * * *
ETL_PER_QUERY=30
ETL_MIN_STARS=1000           # base 슬라이스 스타 하한(>=). 0 = 제한 없음

# 신생 트렌드 슬라이스 (조건마다 created:>윈도우 검색을 병행 수집)
ETL_TREND_WINDOW_DAYS=90     # '신생'으로 보는 생성 후 일수 (수집·rising 노출 공통)
ETL_TREND_MIN_STARS=50       # 신생 슬라이스 전용 스타 하한 (base 하한과 별도)

# 수동 수집 일일 한도 (KST 자정 리셋)
MAX_MANUAL_ETL_PER_DAY=10

# CORS (프론트 dev 서버)
CORS_ORIGIN=http://localhost:5173
